{
  "functions": [
    {
      "source": "functions/getLIRRDepartures",
      "codebase": "lirr",
      "ignore": ["node_modules", ".git", "firebase-debug.log", "*.local"]
    },
    {
      "source": "functions/getFerrySchedule",
      "codebase": "ferry",
      "ignore": ["node_modules", ".git", "firebase-debug.log", "*.local"]
    }
  ],
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/lirrSchedule",
        "function": "getLirrSchedule",
        "region": "us-east1"
      },
      {
        "source": "/api/lirrRealtime",
        "function": "getLirrRealtime",
        "region": "us-east1"
      },
      {
        "source": "/api/lirrScheduleLive",
        "function": "getLirrScheduleLive",
        "region": "us-east1"
      },
      {
        "source": "/api/ferrySchedule",
        "function": "getFerrySchedule",
        "region": "us-east1"
      },
      {
        "source": "/api/forceIngestSayvilleFerryPines",
        "function": "forceIngestSayvilleFerryPines",
        "region": "us-east1"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
